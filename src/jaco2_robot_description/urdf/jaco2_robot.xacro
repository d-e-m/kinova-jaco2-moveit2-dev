<?xml version="1.0"?>
<robot name="jaco2_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">


  <xacro:arg name="is_ignition" default="true"/>

  <xacro:include filename="$(find jaco2_robot_description)/urdf/jaco2_robot_gazebo.xacro" />
  <xacro:include filename="$(find jaco2_robot_description)/urdf/jaco2_robot_ros2_control.xacro" />

  <xacro:property name="PI" value="3.14159265359" />

  <link name="world"/>

  <joint name="jaco2_robot_link_base_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="world" />
    <child link="jaco2_robot_link_base" />
  </joint>

  <link name="jaco2_robot_link_base">
    <visual>
      <geometry>
        <mesh filename="package://jaco2_robot_description/meshes/base.STL"/>
      </geometry>
      <material name="carbon_fiber">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://jaco2_robot_description/meshes/base.STL" />
      </geometry>
    </collision>
    <inertial>
      <mass value="0.467" />
      <origin xyz="0 0 0.1255" rpy="0 ${PI} 0"/>
      <inertia ixx="0.00544252" ixy="0" ixz="0" iyy="0.00544252" iyz="0" izz="0.0093568" />
    </inertial>
  </link>

  <joint name="jaco2_robot_joint_1" type="continuous">
    <parent link="jaco2_robot_link_base" />
    <child link="jaco2_robot_link_1" />
    <axis xyz="0 0 1" />
    <origin xyz="0 0 0.15675" rpy="0 0 0" />
    <limit lower="${-2*PI}" upper="${2*PI}" effort="40" velocity="${36*PI/180}" />
    <dynamics damping="100.0" friction="5.0"/>
  </joint>

  <link name="jaco2_robot_link_1">
    <visual>
      <origin xyz="0 -0.002 0" rpy="0 ${PI} 0"/>
      <geometry>
        <mesh filename="package://jaco2_robot_description/meshes/shoulder.STL" />
      </geometry>
      <material name="carbon_fiber">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <visual>
      <geometry>
          <mesh filename="package://jaco2_robot_description/meshes/ring_big.STL"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 -0.002 0" rpy="0 ${PI} 0"/>
      <geometry>
        <mesh filename="package://jaco2_robot_description/meshes/shoulder.STL" />
      </geometry>
    </collision>
    <inertial>
      <mass value="0.7477" />
      <origin xyz="0 -0.002 0" rpy="0 0 0"/>
      <inertia ixx="0.00869821" ixy="0" ixz="0" iyy="0.014954" iyz="0" izz="0.00869821" />
    </inertial>
  </link>

  <joint name="jaco2_robot_joint_2" type="revolute">
    <parent link="jaco2_robot_link_1" />
    <child link="jaco2_robot_link_2" />
    <axis xyz="0 -1 0" />
    <origin xyz="0 0.0016 0.11875" rpy="0 -${PI} 0" />
    <limit lower="-${(312.0/180.0)*PI}" upper="-${(47.0/180.0)*PI}" effort="80.0" velocity="${36.0*(PI/180.0)}" />
    <dynamics damping="10.0" friction="5.0"/>
  </joint>

  <link name="jaco2_robot_link_2">
    <visual>
      <origin xyz="0 0 0" rpy="-${PI/2} 0 ${PI}"/>
      <geometry>
        <mesh filename="package://jaco2_robot_description/meshes/arm.STL" />
      </geometry>
      <material name="carbon_fiber">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="-${PI/2} 0 ${PI}"/>
      <geometry>
          <mesh filename="package://jaco2_robot_description/meshes/ring_big.STL"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="-${PI/2} 0 ${PI}"/>
      <geometry>
          <mesh filename="package://jaco2_robot_description/meshes/ring_big.STL"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.99" />
      <origin xyz="0 -0.2065 0" rpy="0 0 0"/>
      <inertia ixx="0.0200062" ixy="0" ixz="0" iyy="0.0198" iyz="0" izz="0.0200062" />
    </inertial>
  </link>

  <joint name="jaco2_robot_joint_3" type="revolute">
    <parent link="jaco2_robot_link_2"/>
    <child link="jaco2_robot_link_3"/>
    <axis xyz="0 -1 0"/>
    <limit effort="40.0" lower="-${341/180*PI}" upper="-${19/180*PI}" velocity="${36*PI/180}"/>
    <origin rpy="0 ${PI} 0" xyz="0 0 0.407622"/>
    <dynamics damping="10.0" friction="5.0"/>
  </joint>

  <link name="jaco2_robot_link_3">
    <visual>
      <origin rpy="${PI/2} 0 ${PI}" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://jaco2_robot_description/meshes/forearm.dae"/>
      </geometry>
      <material name="carbon_fiber">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <visual>
      <origin rpy="${PI/2} 0 ${PI}" xyz="0 0 0"/>
      <geometry>
          <mesh filename="package://jaco2_robot_description/meshes/ring_big.STL"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="${PI/2} 0 ${PI}" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://jaco2_robot_description/meshes/arm_half_2.dae"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.4606"/>
      <origin rpy="0 0 0" xyz="0 -0.081 -0.0086"/>
      <inertia ixx="0.0004321316048" ixy="0" ixz="0" iyy="0.0004321316048" iyz="0" izz="0.00020727"/>
    </inertial>
  </link>

  <joint name="jaco2_robot_joint_4" type="continuous">
    <parent link="jaco2_robot_link_3"/>
    <child link="jaco2_robot_link_4"/>
    <axis xyz="0 0 1"/>
    <limit effort="20.0" lower="${-2*PI}" upper="${2*PI}" velocity="${46*PI/180}"/>
    <origin rpy="0 0 0" xyz="0 -0.015 0.279056"/>
  </joint>

  <link name="jaco2_robot_link_4">
    <visual>
      <origin rpy="${PI} 0 0" xyz="0 0 -0.0646992"/>
      <geometry>
        <mesh filename="package://jaco2_robot_description/meshes/wrist.dae"/>
      </geometry>
      <material name="carbon_fiber">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <visual>
      <origin rpy="${PI} 0 0" xyz="0 0 -0.0646992"/>
      <geometry>
          <mesh filename="package://jaco2_robot_description/meshes/ring_small.STL"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="${PI} 0 0" xyz="0 0 -0.0646992"/>
      <geometry>
        <mesh filename="package://jaco2_robot_description/meshes/wrist.dae"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.4263667"/>
      <origin rpy="0 0 0" xyz="0 -0.037 -0.0642"/>
      <inertia ixx="0.00179094" ixy="0" ixz="0" iyy="0.00179094" iyz="0" izz="0.00357"/>
    </inertial>
  </link>

  <joint name="jaco2_robot_joint_5" type="continuous">
    <parent link="jaco2_robot_link_4"/>
    <child link="jaco2_robot_link_5"/>
    <axis xyz="0 0 -1"/>
    <limit effort="20.0" lower="${-2*PI}" upper="${2*PI}" velocity="${46*PI/180}"/>
    <origin rpy="-${PI/3} 0 0" xyz="0 0.0356619 0.001"/>
  </joint>

  <link name="jaco2_robot_link_5">
    <visual>
      <origin rpy="0 ${PI} 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://jaco2_robot_description/meshes/wrist.dae"/>
      </geometry>
      <material name="carbon_fiber">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <visual>
      <origin rpy="0 0 ${PI}" xyz="0 0 0"/>
      <geometry>
          <mesh filename="package://jaco2_robot_description/meshes/ring_small.STL"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 ${PI} 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://jaco2_robot_description/meshes/wrist.dae"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.4263667"/>
      <origin rpy="0 0 0" xyz="0 -0.037 -0.0642"/>
      <inertia ixx="0.00179094" ixy="0" ixz="0" iyy="0.00179094" iyz="0" izz="0.00357"/>
    </inertial>
  </link>

  <joint name="jaco2_robot_joint_6" type="continuous">
    <parent link="jaco2_robot_link_5"/>
    <child link="jaco2_robot_link_6"/>
    <axis xyz="0 0 1"/>
    <limit effort="20.0" velocity="0.837758040957"/>
    <origin rpy="${PI/3} 0 0" xyz="0 -0.045 0.07"/>
  </joint>

  <link name="jaco2_robot_link_6">
    <visual>
      <origin rpy="${PI} 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://jaco2_robot_description/meshes/hand_3finger.dae"/>
      </geometry>
      <material name="carbon_fiber">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <visual>
      <origin rpy="${PI} 0 0" xyz="0 0 0"/>
      <geometry>
          <mesh filename="package://jaco2_robot_description/meshes/ring_small.STL"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="${PI} 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://jaco2_robot_description/meshes/hand_3finger.dae"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.424"/>
      <origin rpy="0 0 0" xyz="0 0 -0.06"/>
      <inertia ixx="0.0003144" ixy="0" ixz="0" iyy="0.0003144" iyz="0" izz="0.0001737"/>
    </inertial>
  </link>

  <joint name="jaco2_robot_joint_finger_1" type="revolute">
    <parent link="jaco2_robot_link_6" />
    <child link="jaco2_robot_link_finger_1" />
    <axis xyz="1 0 0" />
    <origin xyz="0.0035 -0.0315 0.1145" rpy="${PI/2} ${PI/36} -${PI/18}" />
    <limit lower="0" upper="-1.51" effort="2" velocity="1" />
  </joint>

  <link name="jaco2_robot_link_finger_1">
    <visual>
      <origin xyz="0 0 0" rpy="0 -${PI/2} 0" />
      <geometry>
        <mesh filename="package://jaco2_robot_description/meshes/finger_proximal.STL" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 -${PI/2}" />
      <geometry>
        <mesh filename="package://jaco2_robot_description/meshes/finger_proximal.STL" />
      </geometry>
    </collision>
    <inertial>
      <mass value="0.01" />
      <origin xyz="0.022 0 0" rpy="0 0 0" />
      <inertia ixx="0.00001075" ixy="0" ixz="0" iyy="0.00001075" iyz="0" izz="0.00002" />
    </inertial>
  </link>

  <joint name="jaco2_robot_joint_finger_tip_1" type="revolute">
    <parent link="jaco2_robot_link_finger_1" />
    <child link="jaco2_robot_link_finger_tip_1" />
    <axis xyz="-1 0 0" />
    <origin xyz="0 -0.002955 0.0445" rpy="0 0 0" />
    <limit lower="0" upper="1.51" effort="2" velocity="1" />
  </joint>

  <link name="jaco2_robot_link_finger_tip_1">
    <visual>
      <origin xyz="0 0 0" rpy="0 -${PI/2} 0" />
      <geometry>
        <mesh filename="package://jaco2_robot_description/meshes/finger_distal.STL" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 -${PI/2} 0" />
      <geometry>
        <mesh filename="package://jaco2_robot_description/meshes/finger_distal.STL" />
      </geometry>
    </collision>
    <inertial>
      <mass value="0.01" />
      <origin xyz="0.022 0 0" rpy="0 0 0" />
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001" />
    </inertial>
  </link>

  <joint name="jaco2_robot_joint_finger_2" type="revolute">
    <parent link="jaco2_robot_link_6" />
    <child link="jaco2_robot_link_finger_2" />
    <axis xyz="1 0 0" />
    <origin xyz="-0.0225 0.0255 0.1155" rpy="-${PI/4} 0 ${PI/18}" />
    <limit lower="0" upper="1.51" effort="2" velocity="1" />
  </joint>

  <link name="jaco2_robot_link_finger_2">
    <visual>
      <origin xyz="0 0 0" rpy="0 -${PI/2} ${PI}" />
      <geometry>
        <mesh filename="package://jaco2_robot_description/meshes/finger_proximal.STL"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 -${PI/2} ${PI}" />
      <geometry>
        <mesh filename="package://jaco2_robot_description/meshes/finger_proximal.STL" />
      </geometry>
    </collision>
    <inertial>
      <mass value="0.01" />
      <origin xyz="0.022 0 0" rpy="0 0 0" />
      <inertia ixx="0.00001075" ixy="0" ixz="0" iyy="0.00001075" iyz="0" izz="0.00002" />
    </inertial>
  </link>


  <joint name="jaco2_robot_joint_finger_tip_2" type="revolute">
    <parent link="jaco2_robot_link_finger_2" />
    <child link="jaco2_robot_link_finger_tip_2" />
    <axis xyz="1 0 0" />
    <origin xyz="0 0.0025 0.0435" rpy="0 0 0" />
    <limit lower="0" upper="1.51" effort="2" velocity="1" />
  </joint>

  <link name="jaco2_robot_link_finger_tip_2">
    <visual>
      <origin xyz="0 0 0" rpy="0 -${PI/2} 0" />
    <geometry>
      <mesh filename="package://jaco2_robot_description/meshes/finger_distal.STL" />
    </geometry>
  </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 -${PI/2} 0" />
      <geometry>
        <mesh filename="package://jaco2_robot_description/meshes/finger_distal.STL" />
      </geometry>
    </collision>
    <inertial>
      <mass value="0.01" />
      <origin xyz="0.022 0 0" rpy="0 0 0" />
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001" />
    </inertial>
  </link>

  <joint name="jaco2_robot_joint_finger_3" type="revolute">
    <parent link="jaco2_robot_link_6" />
    <child link="jaco2_robot_link_finger_3" />
    <axis xyz="1 0 0" />
    <origin xyz="0.0225 0.0255 0.1155" rpy="-${PI/4} 0 -${PI/18}" />
    <limit lower="0" upper="1.51" effort="2" velocity="1" />
  </joint>

  <link name="jaco2_robot_link_finger_3">
    <visual>
      <origin xyz="0 0 0" rpy="0 -${PI/2} ${PI}" />
      <geometry>
        <mesh filename="package://jaco2_robot_description/meshes/finger_proximal.STL" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 -${PI/2} ${PI}" />
      <geometry>
        <mesh filename="package://jaco2_robot_description/meshes/finger_proximal.STL" />
      </geometry>
    </collision>
    <inertial>
      <mass value="0.01" />
      <origin xyz="0.022 0 0" rpy="0 0 0" />
      <inertia ixx="0.00001075" ixy="0" ixz="0" iyy="0.00001075" iyz="0" izz="0.00002" />
    </inertial>
  </link>

  <joint name="jaco2_robot_joint_finger_tip_3" type="revolute">
    <parent link="jaco2_robot_link_finger_3" />
    <child link="jaco2_robot_link_finger_tip_3" />
    <axis xyz="1 0 0" />
    <origin xyz="0 0.0025 0.0435" rpy="0 0 0" />
    <limit lower="0" upper="1.51" effort="2" velocity="1" />
  </joint>

  <link name="jaco2_robot_link_finger_tip_3">
    <visual>
      <origin xyz="0 0 0" rpy="0 -${PI/2} ${PI}" />
      <geometry>
        <mesh filename="package://jaco2_robot_description/meshes/finger_distal.STL" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 -${PI/2} ${PI}" />
      <geometry>
        <mesh filename="package://jaco2_robot_description/meshes/finger_distal.STL" />
      </geometry>
    </collision>
    <inertial>
      <mass value="0.01" />
      <origin xyz="0.022 0 0" rpy="0 0 0" />
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001" />
    </inertial>
  </link>

</robot>